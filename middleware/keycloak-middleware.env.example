PORT=9401
BASE_PATH=/marva/util

#####################################################################
## Keycloak OIDC settings
#####################################################################
VITE_KEYCLOAK_AUTH_PATH=http://localhost:8081/keycloak/
# Optional internal-only override for container networking
# VITE_KEYCLOAK_INTERNAL_AUTH_PATH=http://keycloak:8081/keycloak/
KEYCLOAK_REALM=bluecore

#####################################################################
## Optional override if you prefer a single issuer URL:
## KEYCLOAK_ISSUER=http://localhost:8081/keycloak/realms/bluecore
#####################################################################
KEYCLOAK_CLIENT_ID=bluecore_api
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_REDIRECT_URI=http://localhost:9401/marva/util/auth/callback
KEYCLOAK_SCOPE=openid profile email

#####################################################################
## Optional: force Host / forwarded headers for token endpoint calls.
## Useful when middleware reaches Keycloak through an internal alias (e.g. keycloak:8081)
## but tokens are issued for localhost:8081.
## KEYCLOAK_INTERNAL_HOST_HEADER=localhost:8081
## KEYCLOAK_INTERNAL_FORWARDED_PROTO=http
#####################################################################

#####################################################################
## Where Marva should be sent after login/logout
#####################################################################
MARVA_REDIRECT_BASE=http://localhost:4444/marva/
MARVA_LOGOUT_REDIRECT=http://localhost:4444/marva/

#####################################################################
## Existing Marva util backend to proxy non-auth routes to
#####################################################################
VITE_BLUECORE_API_PATH=http://localhost:3000/
# Optional explicit override:
# UPSTREAM_UTIL_BASE=http://localhost:3000/marva/util

#####################################################################
## Comma-separated feature flags returned from /my-features
#####################################################################
FEATURE_FLAGS=

#####################################################################
## CORS for browser requests from Marva
#####################################################################
CORS_ORIGIN=http://localhost:4444

#####################################################################
## Optional middleware file log path
#####################################################################
MIDDLEWARE_LOG_FILE=./logs/keycloak-middleware.log
